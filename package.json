{
  "name": "seeyue-workflows",
  "private": true,
  "scripts": {
    "test:hooks:smoke": "node tests/hooks/sy-hooks-smoke.cjs",
    "test:skills:core": "node tests/skill-triggering/run-all.cjs --mode local --cases tests/skill-triggering/cases.json",
    "test:skills:core:auto": "node tests/skill-triggering/run-all.cjs --mode auto --timeout-ms 600000 --cases tests/skill-triggering/cases.auto.json",
    "test:skills:core:runner": "node tests/skill-triggering/run-all.cjs --mode runner --timeout-ms 600000 --cases tests/skill-triggering/cases.auto.json",
    "test:skills:smoke:auto": "node tests/skill-triggering/run-all.cjs --mode auto --max-turns 2 --timeout-ms 180000 --cases tests/skill-triggering/cases.smoke.json",
    "test:skills:smoke:runner": "node tests/skill-triggering/run-all.cjs --mode runner --max-turns 2 --timeout-ms 180000 --cases tests/skill-triggering/cases.smoke.json",
    "test:skills:constraints": "node tests/skill-triggering/run-all.cjs --mode local --cases tests/skill-triggering/cases.constraints.json",
    "test:skills:clean-output": "node scripts/cleanup-skill-trigger-output.cjs",
    "test:all": "npm run test:hooks:smoke && npm run test:skills:core && npm run test:skills:constraints",
    "test:runtime:specs": "node tests/runtime/run-spec-fixtures.cjs",
    "test:runtime:store": "node tests/runtime/run-runtime-store.cjs",
    "test:runtime:checkpoints": "node tests/runtime/run-checkpoint-fixtures.cjs",
    "test:runtime:context": "node tests/runtime/run-context-fixtures.cjs",
    "test:runtime:recovery": "node tests/runtime/run-recovery-fixtures.cjs",
    "test:runtime:router": "node tests/router/run-router-fixtures.cjs",
    "test:runtime:policy": "node tests/policy/run-policy-fixtures.cjs",
    "test:runtime:kernel": "node tests/runtime/run-engine-kernel.cjs",
    "test:runtime:controller": "node tests/runtime/run-controller-fixtures.cjs",
    "test:runtime:bootstrap": "node tests/runtime/run-bootstrap-fixtures.cjs",
    "test:runtime:repair": "node tests/runtime/run-state-repair-fixtures.cjs",
    "test:runtime:transition": "node tests/runtime/run-transition-fixtures.cjs",
    "test:runtime:coverage": "node tests/runtime/run-coverage-adapter-fixtures.cjs",
    "test:runtime:report": "node tests/runtime/run-report-builder-fixtures.cjs",
    "test:runtime:p2": "npm run test:runtime:router && npm run test:runtime:policy && npm run test:runtime:kernel",
    "runtime:run": "node scripts/runtime/controller.cjs --root . --mode run",
    "runtime:resume": "node scripts/runtime/controller.cjs --root . --mode resume",
    "runtime:verify": "node scripts/runtime/controller.cjs --root . --mode verify",
    "runtime:verify:write-report": "node scripts/runtime/controller.cjs --root . --mode verify --write-report",
    "runtime:new-run": "node scripts/runtime/bootstrap-run.cjs --root .",
    "runtime:repair": "node scripts/runtime/state-repair.cjs --root . --write",
    "runtime:coverage:write": "node scripts/runtime/coverage-adapter.cjs --root . --write",
    "test:e2e:engine-conformance": "node tests/e2e/run-engine-conformance.cjs --all",
    "test:e2e:doc-link-check": "node tests/e2e/run-doc-link-check.cjs",
    "test:e2e:release": "node tests/e2e/run-release-fixtures.cjs",
    "test:runtime:approval": "node tests/runtime/run-approval-resolution-fixtures.cjs",
    "runtime:approval:resolve": "node scripts/runtime/approval-resolution.cjs --root .",
    "test:output:templates": "node tests/output/run-output-template-fixtures.cjs",
    "test:output:log": "node tests/output/run-output-log-fixtures.cjs"
  },
  "version": "0.2.0",
  "description": "Standalone workflow repository for seeyue skills, hooks, tests, and docs.",
  "license": "MIT",
  "engines": {
    "node": ">=22",
    "python": ">=3.11"
  }
}
